# =====================================================================
# GHN Dashboard — Railway Environment Variables
# Copy file này thành .env khi dev local, hoặc đặt trực tiếp trên Railway
# KHÔNG commit file .env thực vào Git
# =====================================================================

# ---- Telegram Bot ----
# Lấy từ BotFather: /newbot → /revoke để reset token cũ
TELEGRAM_BOT_TOKEN=your_new_telegram_bot_token_here

# Chat ID của group nhận báo cáo (số âm cho supergroup)
WARN_CHAT_ID=-1002712779761

# ---- Dashboard Authentication ----
# Thay username/password mặc định bằng giá trị riêng của bạn
DASH_USER=ten_dang_nhap_cua_ban
DASH_PASS=mat_khau_manh_tai_day_min_12_ky_tu

# ---- Admin Key ----
# Dùng để truy cập /api/bot/status và /api/bot/test-warning
# Sinh ngẫu nhiên: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=random_32_char_admin_key_here

# ---- Google Sheets (tùy chọn — có default trong code) ----
# Uncomment nếu muốn ẩn hoàn toàn Sheet ID khỏi source code
# SHEET_ID=1Y6ty2RlGYh7Zpo4V1xOUQChyag1p15FvyxBQNaaPlCk
# ODO_SHEET_ID=1frGuwcXD3oTcvY8wt62CqA3j0i6Ub2YrksF_tUIFrcY

# ---- Gemini API Key ----
# Lấy từ https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_new_gemini_api_key_here
